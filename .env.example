# ══════════════════════════════════════════════
# SafeRoads SN — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# ── Base de données PostgreSQL/PostGIS ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saferoads
DB_USER=saferoads_user
DB_PASSWORD=changeme_securise

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ── Chemins données ──
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
MODELS_DIR=models

# ── Open-Meteo (gratuit, pas de clé requise) ──
WEATHER_API_URL=https://archive-api.open-meteo.com/v1/archive

# ── Coordonnées Sénégal (bbox) ──
SENEGAL_BBOX_NORTH=16.7
SENEGAL_BBOX_SOUTH=12.3
SENEGAL_BBOX_WEST=-17.6
SENEGAL_BBOX_EAST=-11.3

# ── Kaggle (optionnel, pour téléchargement automatique) ──
KAGGLE_USERNAME=
KAGGLE_KEY=
